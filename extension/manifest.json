{
  "manifest_version": 3,
  "name": "Nano Chat (jaato)",
  "version": "0.1.0",
  "description": "Chat with Chrome's on-device Gemini Nano through the jaato WebSocket facade.",
  "key": "",
  "permissions": ["sidePanel", "debugger", "tabs"],
  "background": { "service_worker": "background.js" },
  "action": { "default_title": "Open Nano Chat" },
  "side_panel": { "default_path": "sidepanel.html" },
  "web_accessible_resources": [
    { "resources": ["host.html"], "matches": ["<all_urls>"] }
  ]
}
